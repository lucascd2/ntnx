# Nutanix Prism Central Connection
PRISM_CENTRAL_URL=https://prism-central.example.com:9440
USERNAME=admin
PASSWORD=your-password-here

# Exporter Configuration
PORT=8080
SCRAPE_INTERVAL=300

# TLS Verification (set to false for self-signed certs)
TLS_VERIFY=true

# Optional: Logging
LOG_LEVEL=INFO
